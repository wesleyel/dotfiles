[alias]
    br = branch
    co = checkout
    last = log -1 --stat
    st = status -sb

[core]
    editor = vim

[fetch]
    prune = true

[include]
    path = ~/.config/git/local.conf

[init]
    defaultBranch = main

[pull]
    rebase = false

[push]
    autoSetupRemote = true

[rebase]
    autoStash = true

[filter "lfs"]
    clean = git-lfs clean -- %f
    smudge = git-lfs smudge -- %f
    process = git-lfs filter-process
    required = true
[gpg]
	format = ssh
[gpg "ssh"]
	program = /Applications/1Password.app/Contents/MacOS/op-ssh-sign
[commit]
	gpgsign = true
